<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFrameworks>net8.0;net9.0;net10.0;</TargetFrameworks>

    <ServerGarbageCollection>true</ServerGarbageCollection>

    <!-- no useless ref -->
