  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="SimpleW" Version="26.0.0-rc.20260329-1636" />
    <PackageReference Include="SimpleW.Helper.Hosting" Version="26.0.0-rc.20260329-1636" />
    <PackageReference Include="SimpleW.Helper.Razor" Version="26.0.0-rc.20260329-1636" />
  </ItemGroup>

  <ItemGroup>
    <None Update="Views\About.cshtml">
